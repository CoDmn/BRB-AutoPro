rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "corentindamian@gmail.com" ||
        request.auth.token.email == "brbautopro@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidContactRequest(data) {
      return data.keys().hasAll(['name', 'phone', 'email', 'subject', 'message', 'status', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
             data.subject is string && data.subject.size() <= 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 2000 &&
             data.status == 'new' &&
             data.createdAt == request.time;
    }

    function isValidImportRequest(data) {
      return data.keys().hasAll(['brand', 'model', 'year', 'budget', 'email', 'phone', 'options', 'status', 'createdAt']) &&
             data.brand is string && data.brand.size() <= 100 &&
             data.model is string && data.model.size() <= 100 &&
             data.year is string && data.year.size() <= 10 &&
             data.budget is string && data.budget.size() <= 50 &&
             data.email is string && data.email.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.options is string && data.options.size() <= 1000 &&
             data.status == 'new' &&
             data.createdAt == request.time;
    }

    function isValidEstimationRequest(data) {
      return data.keys().hasAll(['brand', 'model', 'year', 'km', 'email', 'status', 'createdAt']) &&
             data.brand is string && data.brand.size() <= 100 &&
             data.model is string && data.model.size() <= 100 &&
             data.year is string && data.year.size() <= 10 &&
             data.km is string && data.km.size() <= 20 &&
             data.email is string && data.email.size() <= 100 &&
             data.status == 'new' &&
             data.createdAt == request.time;
    }

    function isValidInventoryItem(data) {
      let requiredFields = ['brand', 'model', 'name', 'price', 'year', 'km', 'fuel', 'gearbox', 'img', 'images', 'createdAt', 'updatedAt'];
      return data.keys().hasAll(requiredFields) &&
             data.brand is string && data.brand.size() <= 500 &&
             data.model is string && data.model.size() <= 500 &&
             data.name is string && data.name.size() <= 500 &&
             data.price is string && data.price.size() <= 500 &&
             data.year is string && data.year.size() <= 100 &&
             data.km is string && data.km.size() <= 100 &&
             data.fuel is string && data.fuel.size() <= 200 &&
             data.gearbox is string && data.gearbox.size() <= 200 &&
             data.img is string && data.img.size() <= 1048576 &&
             data.images is list && data.images.size() <= 10 &&
             (data.keys().hasAny(['details']) ? data.details is string && data.details.size() <= 20000 : true) &&
             (data.keys().hasAny(['isFavorite']) ? data.isFavorite is bool : true) &&
             data.updatedAt == request.time;
    }

    function isValidDetailingGallery(data) {
      return data.keys().hasAll(['beforeImg', 'afterImg', 'beforeDesc', 'afterDesc', 'createdAt', 'updatedAt']) &&
             data.beforeImg is string && data.beforeImg.size() <= 1048576 &&
             data.afterImg is string && data.afterImg.size() <= 1048576 &&
             data.beforeDesc is string && data.beforeDesc.size() <= 5000 &&
             data.afterDesc is string && data.afterDesc.size() <= 5000 &&
             (data.keys().hasAny(['isFavorite']) ? data.isFavorite is bool : true) &&
             data.updatedAt == request.time;
    }

    function isValidAppointment(data) {
      let requiredFields = ['firstName', 'lastName', 'phone', 'email', 'carModel', 'date', 'status', 'createdAt', 'updatedAt'];
      return data.keys().hasAll(requiredFields) &&
             data.firstName is string && data.firstName.size() <= 100 &&
             data.lastName is string && data.lastName.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.email is string && data.email.size() <= 100 &&
             data.carModel is string && data.carModel.size() <= 200 &&
             data.date is string &&
             data.status in ['pending', 'accepted', 'refused', 'cancelled'] &&
             (!('googleEventId' in data) || data.googleEventId is string) &&
             data.updatedAt == request.time;
    }

    // --- Collections ---

    match /admins/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow write: if false;
    }

    match /contactRequests/{requestId} {
      allow create: if isValidId(requestId) && isValidContactRequest(incoming());
      allow read, list, delete: if isAdmin();
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'isRead', 'isFavorite', 'updatedAt'])
      );
    }

    match /importRequests/{requestId} {
      allow create: if isValidId(requestId) && isValidImportRequest(incoming());
      allow read, list, delete: if isAdmin();
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'isRead', 'isFavorite', 'updatedAt'])
      );
    }

    match /estimationRequests/{requestId} {
      allow create: if isValidId(requestId) && isValidEstimationRequest(incoming());
      allow read, list, delete: if isAdmin();
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'isRead', 'isFavorite', 'updatedAt'])
      );
    }

    match /inventory/{itemId} {
      allow read: if true;
      allow list: if true;
      allow create: if isAdmin() && isValidInventoryItem(incoming());
      allow delete: if isAdmin();
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasAny(['isFavorite', 'updatedAt', 'name', 'price', 'year', 'km', 'fuel', 'gearbox', 'img', 'images', 'details']) ||
        isValidInventoryItem(incoming())
      );
    }

    // (Helper isValidInventoryItemForUpdate removed as it is now redundant)

    match /detailingGalleries/{galleryId} {
      allow read: if true;
      allow list: if true;
      allow create: if isAdmin() && isValidDetailingGallery(incoming());
      allow delete: if isAdmin();
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasAny(['beforeImg', 'afterImg', 'beforeDesc', 'afterDesc', 'isFavorite', 'updatedAt']) ||
        isValidDetailingGallery(incoming())
      );
    }

    match /appointments/{appointmentId} {
      allow create: if isValidId(appointmentId) && isValidAppointment(incoming()) && incoming().createdAt == request.time;
      allow read, list, delete, update: if isAdmin();
    }
  }
}
