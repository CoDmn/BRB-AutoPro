{
  "entities": {
    "ContactRequest": {
      "title": "ContactRequest",
      "description": "A submission from the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "maxLength": 100 },
        "phone": { "type": "string", "maxLength": 20 },
        "email": { "type": "string", "format": "email", "maxLength": 100 },
        "subject": { "type": "string", "maxLength": 100 },
        "message": { "type": "string", "maxLength": 2000 },
        "status": { "type": "string", "enum": ["new", "read", "resolved"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "phone", "email", "subject", "message", "status", "createdAt"]
    },
    "ImportRequest": {
      "title": "ImportRequest",
      "description": "A submission from the vehicle import form.",
      "type": "object",
      "properties": {
        "brand": { "type": "string", "maxLength": 100 },
        "model": { "type": "string", "maxLength": 100 },
        "year": { "type": "string", "maxLength": 10 },
        "budget": { "type": "string", "maxLength": 50 },
        "email": { "type": "string", "format": "email", "maxLength": 100 },
        "phone": { "type": "string", "maxLength": 20 },
        "options": { "type": "string", "maxLength": 1000 },
        "status": { "type": "string", "enum": ["new", "read", "resolved"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["brand", "model", "year", "budget", "email", "phone", "options", "status", "createdAt"]
    },
    "EstimationRequest": {
      "title": "EstimationRequest",
      "description": "A submission from the vehicle estimation form.",
      "type": "object",
      "properties": {
        "brand": { "type": "string", "maxLength": 100 },
        "model": { "type": "string", "maxLength": 100 },
        "year": { "type": "string", "maxLength": 10 },
        "km": { "type": "string", "maxLength": 20 },
        "email": { "type": "string", "format": "email", "maxLength": 100 },
        "status": { "type": "string", "enum": ["new", "read", "resolved"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["brand", "model", "year", "km", "email", "status", "createdAt"]
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "description": "A vehicle available in stock.",
      "type": "object",
      "properties": {
        "brand": { "type": "string", "maxLength": 100 },
        "model": { "type": "string", "maxLength": 100 },
        "name": { "type": "string", "maxLength": 200 },
        "price": { "type": "string", "maxLength": 50 },
        "year": { "type": "string", "maxLength": 10 },
        "km": { "type": "string", "maxLength": 20 },
        "fuel": { "type": "string", "maxLength": 50 },
        "gearbox": { "type": "string", "maxLength": 50 },
        "doors": { "type": "string", "maxLength": 10 },
        "seats": { "type": "string", "maxLength": 10 },
        "type": { "type": "string", "maxLength": 50 },
        "color": { "type": "string", "maxLength": 50 },
        "critair": { "type": "string", "maxLength": 10 },
        "cv": { "type": "string", "maxLength": 10 },
        "ch": { "type": "string", "maxLength": 10 },
        "specificities": { "type": "string", "maxLength": 2000 },
        "details": { "type": "string", "maxLength": 20000 },
        "img": { "type": "string", "maxLength": 1000 },
        "images": { 
          "type": "array", 
          "items": { "type": "string" },
          "maxItems": 4
        },
        "isFavorite": { "type": "boolean" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["brand", "model", "name", "price", "year", "km", "fuel", "gearbox", "img", "images", "createdAt", "updatedAt"]
    },
    "DetailingGallery": {
      "title": "DetailingGallery",
      "description": "Before/After pictures for detailing.",
      "type": "object",
      "properties": {
        "beforeImg": { "type": "string", "maxLength": 1048576 },
        "afterImg": { "type": "string", "maxLength": 1048576 },
        "beforeDesc": { "type": "string", "maxLength": 5000 },
        "afterDesc": { "type": "string", "maxLength": 5000 },
        "isFavorite": { "type": "boolean" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["beforeImg", "afterImg", "beforeDesc", "afterDesc", "createdAt", "updatedAt"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "An appointment booking.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string", "maxLength": 100 },
        "lastName": { "type": "string", "maxLength": 100 },
        "phone": { "type": "string", "maxLength": 20 },
        "email": { "type": "string", "format": "email", "maxLength": 100 },
        "carModel": { "type": "string", "maxLength": 200 },
        "date": { "type": "string", "format": "date-time" },
        "service": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "refused", "cancelled"] },
        "message": { "type": "string" },
        "googleEventId": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["firstName", "lastName", "phone", "email", "carModel", "date", "status", "createdAt", "updatedAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "An admin user.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "maxLength": 100 },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "contactRequests/{requestId}": {
      "schema": "ContactRequest",
      "description": "Stores user submitted contact requests"
    },
    "importRequests/{requestId}": {
      "schema": "ImportRequest",
      "description": "Stores user submitted import requests"
    },
    "estimationRequests/{requestId}": {
      "schema": "EstimationRequest",
      "description": "Stores user submitted estimation requests"
    },
    "inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Stores current available vehicles"
    },
    "detailingGalleries/{galleryId}": {
      "schema": "DetailingGallery",
      "description": "Stores before and after pics of detailing jobs"
    },
    "admins/{userId}": {
      "schema": "Admin",
      "description": "Stores authorized admin users"
    },
    "appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Stores appointment bookings"
    }
  }
}
